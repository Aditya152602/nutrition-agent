# ═══════════════════════════════════════════════════════════════
# 🔐 AI Nutrition Agent — Environment Configuration
#
# HOW TO USE:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in your actual values below
#   3. NEVER commit the .env file to Git
# ═══════════════════════════════════════════════════════════════

# ──────────────────────────────────────────────────────────────
# IBM CLOUD / WATSONX.AI CREDENTIALS
# Get these from: https://cloud.ibm.com
# ──────────────────────────────────────────────────────────────

# Step 1: IBM Cloud API Key
#   IBM Cloud → Manage → Access (IAM) → API Keys → Create
IBM_API_KEY=your_ibm_cloud_api_key_here

# Step 2: Watsonx.ai Project ID
#   Watson Studio → Your Project → Manage → General → Project ID
WATSONX_PROJECT_ID=your_watsonx_project_id_here

# Step 3: Watsonx.ai Service URL (choose your region)
#   US South  → https://us-south.ml.cloud.ibm.com   (recommended)
#   EU Germany → https://eu-de.ml.cloud.ibm.com
#   UK South  → https://eu-gb.ml.cloud.ibm.com
#   AP Sydney → https://au-syd.ml.cloud.ibm.com
#   Tokyo     → https://jp-tok.ml.cloud.ibm.com
WATSONX_URL=https://us-south.ml.cloud.ibm.com

# Step 4: Granite Model ID
#   ibm/granite-3-8b-instruct       ← Recommended (fast, accurate)
#   ibm/granite-13b-instruct-v2     ← More powerful (slower)
#   ibm/granite-3-2b-instruct       ← Fastest (less detailed)
WATSONX_MODEL_ID=ibm/granite-3-8b-instruct

# ──────────────────────────────────────────────────────────────
# FLASK APP SETTINGS
# ──────────────────────────────────────────────────────────────

# Generate a random secret key: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=change_this_to_a_random_secret_key_32chars

# Set to "true" for development (shows debug errors)
FLASK_DEBUG=false

# Port to run on (default: 5000)
PORT=5000
